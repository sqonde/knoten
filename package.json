{
  "name": "@sqonde/knoten",
  "version": "1.0.0",
  "description": "Minimal React data-fetching hooks: useQuery, useMutation, invalidate.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=browser --outdir=dist --external react --external zustand && tsc -p tsconfig.build.json",
    "test": "bun test",
    "format": "prettier --write src",
    "prepublishOnly": "bun run build",
    "release:patch": "bun pm version patch && git push --follow-tags",
    "release:minor": "bun pm version minor && git push --follow-tags",
    "release:major": "bun pm version major && git push --follow-tags"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "^19.2.7",
    "prettier": "^3.1.1",
    "react": "^19.2.3",
    "typescript": "^5.3.3",
    "zustand": "^5.0.12"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sqonde/knoten.git"
  },
  "bugs": {
    "url": "https://github.com/sqonde/knoten/issues"
  },
  "homepage": "https://github.com/sqonde/knoten#readme",
  "license": "MIT",
  "keywords": [
    "react",
    "hooks",
    "query",
    "fetch",
    "cache",
    "zustand"
  ]
}